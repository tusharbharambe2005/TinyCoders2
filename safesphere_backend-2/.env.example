# ─────────────────────────────────────────────
#  SafeSphere Backend – Environment Variables
# ─────────────────────────────────────────────

# Django core
SECRET_KEY=change-this-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ┌─────────────────────────────────────────────┐
# │  DATABASE                                   │
# │  Uses Django built-in SQLite by default.    │
# │  No setup required — db.sqlite3 is created  │
# │  automatically on first `python manage.py   │
# │  migrate`.                                  │
# └─────────────────────────────────────────────┘
# (No database variables needed for SQLite)

# ┌─────────────────────────────────────────────┐
# │  FILE STORAGE — pick ONE option             │
# │                                             │
# │  Option 1 · LOCAL  (default, zero config)  │
# │    Files saved to: media/evidence/          │
# │    Set: STORAGE_BACKEND=local               │
# │                                             │
# │  Option 2 · CLOUDINARY  (FREE cloud)        │
# │    Files uploaded to Cloudinary             │
# │    Set: STORAGE_BACKEND=cloudinary          │
# │    Then fill in the CLOUDINARY_* keys below │
# │    Get free account: https://cloudinary.com │
# └─────────────────────────────────────────────┘

STORAGE_BACKEND=cloudinary

# Cloudinary credentials (only needed if STORAGE_BACKEND=cloudinary)
# Sign up free at https://cloudinary.com and get these from your dashboard
CLOUDINARY_CLOUD_NAME=dufpqxo64
